ALCHEMY_API_KEY=
# Optional: default 4EVERLAND pin API token for /api/pin when the client does not send x-cidkeeper-four-everland-token
FOUR_EVERLAND_TOKEN=

# Optional: cap how many NFT rows are processed for ZIP on serverless (default: 150)
MAX_NFTS_FOR_ZIP=150

